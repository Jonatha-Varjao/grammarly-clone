{
  "name": "grammarly-clone",
  "version": "1.0.0",
  "description": "AI Writing Assistant - Grammar and tone transformation extension",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch build.ts",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": ">=10",
    "eslint-config-xo": "^0.50.0",
    "globals": "^17.4.0",
    "typescript": "^5.6.0"
  }
}
